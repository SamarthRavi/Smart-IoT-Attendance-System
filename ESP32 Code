// ---------- Student Structure ----------
struct Student {
  String name;
  String identifier;
};
std::vector<Student> students;

// ---------- Time Setup ----------
void setupTime() {
  configTime(5 * 3600 + 1800, 0, "pool.ntp.org", "time.google.com"); // IST
  delay(2000);
  time_t now = time(nullptr);
  Serial.print("Time synced: ");
  Serial.println(ctime(&now));
}

String getDateString() {
  time_t now = time(nullptr);
  struct tm t;
  localtime_r(&now, &t);
  char buf[16];
  strftime(buf, sizeof(buf), "%Y-%m-%d", &t);
  return String(buf);
}

String getTimeString() {
  time_t now = time(nullptr);
  struct tm t;
  localtime_r(&now, &t);
  char buf[16];
  strftime(buf, sizeof(buf), "%H:%M:%S", &t);
  return String(buf);
}

// ---------- Fetch Students from Firebase ----------
void loadStudentsFromFirebase() {
  Serial.println("Fetching student list from Firebase...");

  if (Firebase.RTDB.getJSON(&fbdo, "/students")) {
    FirebaseJson json;
    json.setJsonData(fbdo.payload());
    FirebaseJsonData temp, nameData, idData;

    students.clear();

    size_t count = json.iteratorBegin();
    for (size_t i = 0; i < count; i++) {
      FirebaseJson::IteratorValue value = json.valueAt(i);
      String key = value.key;

      if (key == "" || key == "name" || key == "identifier")
        continue;

      if (json.get(temp, key)) {
        FirebaseJson studentJson;
        studentJson.setJsonData(temp.stringValue);

        if (studentJson.get(nameData, "name") && studentJson.get(idData, "identifier")) {
          students.push_back({nameData.stringValue, idData.stringValue});
          Serial.printf("✅ Loaded student: %s (%s)\n", nameData.stringValue.c_str(), idData.stringValue.c_str());
        }
      }
    }

    json.iteratorEnd();
    Serial.printf("Loaded %d students.\n", students.size());
  } else {
    Serial.printf("Failed to fetch students: %s\n", fbdo.errorReason().c_str());
  }
}

// ---------- Upload Attendance (Fixed Version) ----------
void uploadAttendance(const String &name, const String &identifier, const String &status) {
  String date = getDateString();
  String timeNow = getTimeString();

  // Sanitize Firebase path (remove spaces and invalid chars)
  String safeName = name;
  safeName.replace(" ", "_");
  safeName.replace(".", "_");
  safeName.replace("#", "_");
  safeName.replace("$", "_");
  safeName.replace("[", "_");
  safeName.replace("]", "_");

  String basePath = "/attendance/" + date + "/" + safeName;

  Serial.printf("→ Uploading to Firebase: %s\n", basePath.c_str());

  bool ok1 = Firebase.RTDB.setString(&fbdo, basePath + "/identifier", identifier);
  delay(100);
  bool ok2 = Firebase.RTDB.setString(&fbdo, basePath + "/status", status);
  delay(100);
  bool ok3 = Firebase.RTDB.setString(&fbdo, basePath + "/time", timeNow);
  delay(100);

  if (ok1 && ok2 && ok3) {
    Serial.printf("✅ %s marked %s at %s\n", name.c_str(), status.c_str(), timeNow.c_str());
  } else {
    Serial.printf("❌ Upload failed for %s\n", name.c_str());
    if (!ok1) Serial.printf("  → identifier write failed: %s\n", fbdo.errorReason().c_str());
    if (!ok2) Serial.printf("  → status write failed: %s\n", fbdo.errorReason().c_str());
    if (!ok3) Serial.printf("  → time write failed: %s\n", fbdo.errorReason().c_str());
  }
}

// ---------- BLE Scan ----------
void doBLEScan() {
  Serial.println("\n--- New Scan ---");
  String timeNow = getTimeString();
  Serial.println("Time: " + timeNow);

  BLEScanResults *results = pBLEScan->start(SCAN_TIME_SEC, false);
  int count = results->getCount();
  Serial.printf("Found %d devices\n", count);

  std::vector<String> foundIdentifiers;
  for (int i = 0; i < count; i++) {
    BLEAdvertisedDevice dev = results->getDevice(i);
    String name = dev.getName().c_str();
    if (name.length() > 0) {
      foundIdentifiers.push_back(name);
    }
  }

  for (auto &s : students) {
    bool present = false;
    for (auto &id : foundIdentifiers) {
      if (id.equalsIgnoreCase(s.identifier)) {
        present = true;
        break;
      }
    }
    uploadAttendance(s.name, s.identifier, present ? "Present" : "Absent");
  }

  Serial.println("--- Scan complete ---");
  pBLEScan->clearResults();
}

// ---------- Setup ----------
void setup() {
  Serial.begin(115200);
  delay(1000);
  Serial.println("Starting 24/7 Bluetooth Attendance System...");

  WiFi.begin(WIFI_SSID, WIFI_PASSWORD);
  Serial.print("Connecting to Wi-Fi");
  while (WiFi.status() != WL_CONNECTED) {
    Serial.print(".");
    delay(500);
  }
  Serial.println();
  Serial.println("Wi-Fi Connected! IP: " + WiFi.localIP().toString());

  setupTime();

  config.api_key = API_KEY;
  config.database_url = DATABASE_URL;
  Firebase.reconnectWiFi(true);
  Firebase.signUp(&config, &auth, "", "");
  Firebase.begin(&config, &auth);

  fbdo.setResponseSize(4096);
  config.timeout.serverResponse = 30000;
  config.timeout.wifiReconnect = 10000;
  config.timeout.socketConnection = 10000;

  Serial.println("Firebase initialized.");
  loadStudentsFromFirebase();

  BLEDevice::init("ESP32_Attendance");
  pBLEScan = BLEDevice::getScan();
  pBLEScan->setActiveScan(true);
  Serial.println("BLE initialized.");
}

// ---------- Loop ----------
void loop() {
  unsigned long m = millis();
  if (m - lastScanMillis >= SCAN_INTERVAL_MS) {
    lastScanMillis = m;
    doBLEScan();
  }
  delay(100);
}
